{
  "name": "vite-plus-monorepo",
  "license": "BUSL-1.1",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.18.0"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -F @voidzero-dev/* -F vite-plus -F vite-plus-cli build",
    "bootstrap-cli": "pnpm build && pnpm install-global-cli",
    "bootstrap-cli:ci": "pnpm install-global-cli",
    "install-global-cli": "pnpm --filter=vite-plus-cli copy-binding && npm install -g ./packages/global --force",
    "typecheck": "tsc -b tsconfig.json",
    "lint": "vite lint --type-aware --threads 4",
    "test": "vite test run && pnpm -r snap-test",
    "test:unit": "vite test run",
    "docs:dev": "pnpm --filter=./docs dev",
    "docs:build": "pnpm --filter=./docs build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@oxc-node/cli": "catalog:",
    "@oxc-node/core": "catalog:",
    "@types/node": "catalog:",
    "vite-plus": "workspace:*",
    "@voidzero-dev/vite-plus-tools": "workspace:*",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.@(js|ts|tsx)": [
      "oxlint -- --fix"
    ],
    "*.rs": [
      "cargo fmt --"
    ]
  }
}
