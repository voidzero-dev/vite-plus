{
  "name": "vite-plus-monorepo",
  "license": "BUSL-1.1",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "type": "module",
  "scripts": {
    "bootstrap-cli": "pnpm --filter=@voidzero-dev/* build && pnpm install-global-cli",
    "bootstrap-cli:ci": "pnpm install-global-cli",
    "install-global-cli": "pnpm --filter=@voidzero-dev/global copy-binding && npm install -g ./packages/global",
    "typecheck": "tsc -b tsconfig.json",
    "lint": "vite lint --type-aware --threads 4",
    "test": "vite test run && pnpm -r snap-test",
    "test:unit": "vite test run",
    "docs:dev": "vite run vite-docs#dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@oxc-node/cli": "catalog:",
    "@oxc-node/core": "catalog:",
    "@types/node": "catalog:",
    "@voidzero-dev/vite-plus": "workspace:*",
    "@voidzero-dev/vite-plus-tools": "workspace:*",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "lint-staged": {
    "*.@(js|ts|tsx)": [
      "oxlint -- --fix"
    ],
    "*.rs": [
      "cargo fmt --"
    ]
  }
}
