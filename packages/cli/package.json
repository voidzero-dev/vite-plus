{
  "name": "@voidzero-dev/vite-plus",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vite": "./bin/vite",
    "vite-plus": "./bin/vite"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "oxnode -C dev ./build.ts",
    "snap-test": "tool snap-test",
    "test": "vitest run"
  },
  "files": [
    "bin",
    "dist",
    "binding/index.d.ts",
    "binding/index.js",
    "binding/*.node"
  ],
  "dependencies": {
    "@voidzero-dev/vite-plus-core": "workspace:*",
    "@voidzero-dev/vite-plus-test": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.4.1",
    "@oxc-node/core": "^0.0.32",
    "@voidzero-dev/vite-plus-tools": "workspace:",
    "rolldown": "workspace:*",
    "rolldown-plugin-dts": "catalog:",
    "tsdown": "catalog:",
    "vite": "workspace:*"
  },
  "napi": {
    "binaryName": "vite-plus",
    "packageName": "@vite-plus",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu",
      "aarch64-pc-windows-msvc",
      "x86_64-pc-windows-msvc"
    ]
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./bin": {
      "import": "./dist/bin.js"
    },
    "./binding": {
      "import": "./binding/index.js",
      "types": "./binding/index.d.ts"
    }
  }
}
