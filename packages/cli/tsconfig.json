{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "composite": true,
    "outDir": "./dist",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "skipLibCheck": true,
    "rootDir": "./src",
    "experimentalDecorators": true,
    "customConditions": ["dev"],
    "preserveSymlinks": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist/**/*"]
}
