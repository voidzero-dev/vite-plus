{
  "name": "migration-upgrade-bun-catalog",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.11",
      "onFail": "download"
    }
  },
  "catalog": {
    "vite-plus": "^0.1.20",
    "vitest": "4.1.9"
  }
}
