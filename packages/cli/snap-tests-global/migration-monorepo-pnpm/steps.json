{
  "commands": [
    "vp migrate --no-interactive # migration should merge vite.config.ts and remove oxlintrc and oxfmtrc",
    "cat vite.config.ts # check vite.config.ts",
    "test ! -f .oxlintrc.json # check .oxlintrc.json is removed",
    "test ! -f .oxfmtrc.json # check .oxfmtrc.json is removed",
    "cat package.json # check package.json",
    "cat pnpm-workspace.yaml # check pnpm-workspace.yaml",
    "cat packages/app/package.json # check app package.json",
    "cat packages/utils/package.json # check utils package.json",
    "cat packages/only-oxlint/package.json # check only-oxlint package.json",
    "cat packages/only-oxlint/vite.config.ts # check only-oxlint vite.config.ts",
    "test ! -f packages/only-oxlint/.oxlintrc.json # check only-oxlint .oxlintrc.json is removed"
  ]
}
