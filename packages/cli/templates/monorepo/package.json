{
  "name": "vite-plus-monorepo-template",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "prepare": "vp prepare",
    "ready": "vp fmt && vp lint --type-aware && vp run test -r && vp run build -r",
    "dev": "vp run website#dev"
  },
  "lint-staged": {
    "*": "vp check --fix"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
