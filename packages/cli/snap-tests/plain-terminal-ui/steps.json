{
  "env": {
    "VITE_PLUS_CLI_TEST": "0",
    "VITE_DISABLE_AUTO_INSTALL": "1"
  },
  "commands": [
    "FOO=1 vite run hello",
    "FOO=1 vite run hello # hit cache",

    "FOO=2 vite run hello # env changed",
    "FOO=2 BAR=1 vite run hello # env added",
    "vite run hello # env removed",

    "echo bar > input.txt",
    "vite run hello # input changed",

    "json-edit vite-task.json \"_.tasks.hello.passThroughEnvs=['PTE']\"",
    "vite run hello # passThroughEnvs changed",

    "json-edit vite-task.json \"_.tasks.hello.cwd='subfolder'\"",
    "vite run hello # cwd changed"
  ]
}
