{
  "env": {
    "VITE_DISABLE_AUTO_INSTALL": "1"
  },
  "commands": [
    "vite install --help # print help message",
    "vite install --production --silent # https://docs.npmjs.com/cli/v10/commands/npm-install",
    "ls node_modules",
    "vite install --production --silent # install again hit cache"
  ]
}
