{
  "env": {
    "VITE_DISABLE_AUTO_INSTALL": "1"
  },
  "commands": [
    "vp lint --init",
    "cat vite.config.ts",
    "test ! -f .oxlintrc.json # check .oxlintrc.json is removed",
    "rm vite.config.ts",
    "vp fmt --init",
    "cat vite.config.ts",
    "test ! -f .oxfmtrc.json # check .oxfmtrc.json is removed"
  ]
}
