{
  "ignoredPlatforms": ["linux", "win32"],
  "env": {
    "VITE_DISABLE_AUTO_INSTALL": "1"
  },
  "commands": [
    "vite install --help # print help message",
    "vite install --prod # https://classic.yarnpkg.com/en/docs/cli/install#toc-yarn-install-production-true-false",
    "ls node_modules",
    "vite install --prod # install again hit cache"
  ]
}
