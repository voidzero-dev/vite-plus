#!/usr/bin/env node

// LSP-only wrapper for oxlint.
// This enables IDE extensions (e.g., oxc-vscode) to discover and start the LSP server.
// Binary resolution follows the same approach as `src/resolve-lint.ts`.

if (!process.argv.includes('--lsp')) {
  console.error('This oxlint wrapper is for IDE extension use only (--lsp mode).');
  console.error('To lint your code, run: vp lint');
  process.exit(1);
}

import { createRequire } from 'node:module';
import { dirname, join } from 'node:path';
import { mkdirSync, writeFileSync } from 'node:fs';

const require = createRequire(import.meta.url);
const oxlintMainPath = require.resolve('oxlint');
const oxlintBin = join(dirname(dirname(oxlintMainPath)), 'bin', 'oxlint');

try {
  const { resolveUniversalViteConfig } = await import('../src/resolve-vite-config.js');
  const configJson = await resolveUniversalViteConfig(null, process.cwd());
  const config = JSON.parse(configJson);
  if (config.lint) {
    const cacheDir = join(process.cwd(), 'node_modules', '.cache', 'vite-plus');
    mkdirSync(cacheDir, { recursive: true });
    const configPath = join(cacheDir, 'oxlintrc.json');
    writeFileSync(configPath, JSON.stringify(config.lint));

    // Inject flags before --lsp in process.argv
    const lspIndex = process.argv.indexOf('--lsp');
    const insertArgs = ['-c', configPath];
    if (config.configFile) {
      insertArgs.push('--config-dir', dirname(config.configFile));
    }
    process.argv.splice(lspIndex, 0, ...insertArgs);
  }
} catch {
  // Config resolution failed — oxlint will use its own file-based discovery
}

await import(oxlintBin);
