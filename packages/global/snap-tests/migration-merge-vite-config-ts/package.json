{
  "devDependencies": {
    "vite": "^7.0.0",
    "vitest": "^4.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "oxlint": "1",
    "oxfmt": "1"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
