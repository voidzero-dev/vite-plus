{
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "ready": "vite fmt && vite run lint && vite run test:all && vite run build:all",
    "dev": "vite run website#dev",
    "lint": "vite lint --type-aware",
    "test:all": "vite run -r test",
    "build:all": "vite run -r build"
  },
  "devDependencies": {
    "vite": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "vite": "catalog:",
      "tsdown": "catalog:"
    },
    "peerDependencyRules": {
      "allowAny": [
        "vite"
      ]
    }
  },
  "resolutions": {
    "vite": "catalog:",
    "tsdown": "catalog:"
  }
}
