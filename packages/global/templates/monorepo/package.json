{
  "name": "vite-plus-monorepo-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "scripts": {
    "ready": "vite fmt && vite lint --type-aware && vite run test -r && vite run build -r",
    "dev": "vite run website#dev"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "pnpm": {
    "overrides": {
      "vite": "catalog:",
      "vitest": "catalog:"
    },
    "peerDependencyRules": {
      "allowAny": [
        "vite"
      ]
    }
  },
  "resolutions": {
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
