{
  "version": "1.0.0",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "prebuild"
      ],
      "outputs": [
        "dist/**",
        "build/**"
      ]
    },
    "prebuild": {
      "dependsOn": [
        "typecheck",
        "lint"
      ]
    },
    "test": {
      "dependsOn": [
        "build"
      ],
      "outputs": [
        "coverage/**"
      ]
    },
    "lint": {
      "cache": true
    },
    "typecheck": {
      "cache": true
    },
    "prepare": {
      "cache": false
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "start": {
      "persistent": true,
      "dependsOn": [
        "build"
      ]
    }
  }
}
